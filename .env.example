# .env.example

# 외부에서 Lucy 서비스에 접근할 때 사용하는 주소
# 프로토콜(http:// 또는 https://)을 반드시 포함하세요. (localhost, 127.0.0.1 불가)
# 예: https://cloud.example.com, http://192.168.0.100
EXTERNAL_URL=https://your-domain.com
BROKER_WS_URL=wss://your-domain.com/mqtt

# 호스트에 공개할 포트
# 1024 미만 특권 포트(예: 80, 443)는 rootless Podman 환경에서 OS 설정에 따라
# 사용할 수 없을 수 있습니다. preflight가 compose-up 전에 검증합니다.
HTTP_PORT=80
HTTPS_PORT=443
BROKER_MQTT_PORT=1883
BROKER_WS_PORT=8080
BROKER_WSS_PORT=8081
BROKER_HTTP_PORT=8888

# Lucy 서비스 관리자 계정
# LUCY_ADMIN_NAME 은 바꿀 수 없습니다.
LUCY_ADMIN_EMAIL=admin@edencrew.com
LUCY_ADMIN_PASSWORD=your_service_admin_password
LUCY_ADMIN_NAME=admin

# 데이터베이스 초기화 및 접속 정보
# 초기화 이후 변경시 서비스 이용이 불가능합니다.
DB_ROOT_PASSWORD=your_db_root_password
DB_USERNAME=lucy
DB_PASSWORD=your_db_password

# 타임존 (예: Asia/Seoul, UTC)
TZ=Asia/Seoul

# Linux 환경은 docker-compose 실행 계정의 UID/GID로 변경하세요 (`id` 명령어로 확인)
# HOST_UID=1000
# HOST_GID=1000
