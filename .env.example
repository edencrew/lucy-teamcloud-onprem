# .env.example

# 외부에서 Lucy 서비스에 접근할 때 사용하는 주소입니다.
# 프로토콜(http:// 또는 https://)을 반드시 포함하세요. localhost/127.0.0.1은 운영용으로 쓰지 마세요.
# Docker 기본 compose: 80/443 publish 예) https://teamcloud.example.com
# Podman 기본 compose: 18080/18443 publish 예) http://teamcloud.example.com:18080
# 이 URL은 compose의 host port publish 설정을 자동으로 바꾸지 않습니다.
# port를 바꾸면 compose.*.yml의 gw.ports와 아래 URL들을 함께 수정하세요.
EXTERNAL_URL=https://your-domain.com
BROKER_WS_URL=wss://your-domain.com/mqtt
PUBLIC_BROKER_WS_URL=wss://your-public-domain.com/mqtt

# Lucy 서비스 관리자 계정
# LUCY_ADMIN_NAME 은 바꿀 수 없습니다.
LUCY_ADMIN_EMAIL=admin@edencrew.com
LUCY_ADMIN_PASSWORD=your_service_admin_password
LUCY_ADMIN_NAME=admin

# 데이터베이스 초기화 및 접속 정보
# 초기화 이후 변경시 서비스 이용이 불가능합니다.
DB_ROOT_PASSWORD=your_db_root_password
DB_USERNAME=lucy
DB_PASSWORD=your_db_password

# 타임존 (예: Asia/Seoul, UTC)
TZ=Asia/Seoul

# Linux 서버에서는 compose 실행 계정의 UID/GID로 반드시 확인/설정하세요 (`id` 명령어로 확인)
HOST_UID=1000
HOST_GID=1000
