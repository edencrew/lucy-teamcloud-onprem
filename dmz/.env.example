# DMZ MQTT-over-WebSocket proxy settings.

# Public hostname or IP used by mobile clients.
# Examples:
#   mqtt.company.com
#   203.0.113.10
DMZ_SERVER_NAME=dmz.example.com

# 1: expose WSS on 443 and require ./certs/server.crt,key.
# 0: expose plain WS on 80. Useful for IP-only test/private environments.
DMZ_ENABLE_TLS=1

# Internal Lucy TeamCloud nginx origin. Do not include /mqtt here.
# DMZ nginx preserves the original /mqtt request path when proxying.
# Examples:
#   https://10.0.0.10
#   https://internal-teamcloud.example.com
INTERNAL_MQTT_UPSTREAM=https://internal-teamcloud.example.com

# Host ports exposed on the DMZ server.
DMZ_HTTP_PORT=80
DMZ_HTTPS_PORT=443

# Paths inside the nginx container. Put the actual files under ./certs.
DMZ_TLS_CERTIFICATE=/etc/nginx/certs/server.crt
DMZ_TLS_CERTIFICATE_KEY=/etc/nginx/certs/server.key
