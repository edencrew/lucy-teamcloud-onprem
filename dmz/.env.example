# DMZ proxy settings.

# Public hostname or IP used by external clients. Do not include scheme, path, or port.
# In teamcloud mode, use the canonical TeamCloud DNS host here.
# Examples:
#   mqtt.company.com
#   teamcloud.company.com
#   203.0.113.10
DMZ_SERVER_NAME=dmz.example.com

# mqtt: expose only /mqtt and return 404 for other paths.
# teamcloud: proxy /, /api, /auth, /git, and /mqtt to the internal onprem nginx.
DMZ_PROXY_MODE=mqtt

# 1: expose WSS on 443 and require ./certs/server.crt,key.
# 0: expose plain WS on 80. Useful for IP-only test/private environments.
DMZ_ENABLE_TLS=1

# Internal Lucy TeamCloud nginx origin for mqtt mode. Do not include /mqtt here.
# DMZ nginx preserves the original request path when proxying.
# Examples:
#   https://10.0.0.10
#   https://internal-teamcloud.example.com
INTERNAL_MQTT_UPSTREAM=https://internal-teamcloud.example.com

# Internal Lucy TeamCloud nginx origin for teamcloud mode. Do not include a path.
# If empty, teamcloud mode falls back to INTERNAL_MQTT_UPSTREAM for compatibility.
INTERNAL_TEAMCLOUD_UPSTREAM=

# Host ports exposed on the DMZ server.
# In TLS mode, DMZ_HTTPS_PORT is also used to generate HTTP -> HTTPS redirects.
DMZ_HTTP_PORT=80
DMZ_HTTPS_PORT=443

# Paths inside the nginx container. Put the actual files under ./certs.
DMZ_TLS_CERTIFICATE=/etc/nginx/certs/server.crt
DMZ_TLS_CERTIFICATE_KEY=/etc/nginx/certs/server.key
