# 호스트 환경에 맞게 설정을 덮어쓰는 예제 파일입니다.
# 사용법:
#   1. 이 파일을 docker-compose.override.yml 로 복사
#        cp docker-compose.override.yml.example docker-compose.override.yml
#   2. 필요한 부분의 값을 수정
#   3. docker compose up -d
#
# 가급적 원본 docker-compose.yml 은 직접 수정하지 마세요.

services:
  # ─────────────────────────────────────────────────────────────
  # 호스트 포트 매핑은 기본적으로 .env 의 HTTP_PORT / HTTPS_PORT 로 변경합니다.
  # 이 override 파일은 특정 IP에만 bind 하는 등 고급 설정이 필요할 때 사용하세요.
  #
  # 예:
  #   .env:
  #     HTTP_PORT=8080
  #     HTTPS_PORT=8443
  #     EXTERNAL_URL=https://your-domain.com:8443
  # ─────────────────────────────────────────────────────────────
  gw:
    ports: !override
      - "${HTTP_PORT:-80}:80"
      - "${HTTPS_PORT:-443}:443"
